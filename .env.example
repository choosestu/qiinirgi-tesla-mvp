TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI=https://qiinirgi.com/auth/tesla/callback
TESLA_AUTH_BASE=https://auth.tesla.com
PORT=3000

# Required by Tesla's current Fleet API docs:
# Token exchange must use the fleet-auth domain, and the token `audience`
# must be your region's Fleet API base URL.
TESLA_TOKEN_BASE=https://fleet-auth.prd.vn.cloud.tesla.com
TESLA_API_BASE=https://fleet-api.prd.na.vn.cloud.tesla.com

# Vehicle commands: modern (2021+) vehicles reject unsigned REST commands.
# Run Tesla's Vehicle Command Proxy (github.com/teslamotors/vehicle-command)
# with your virtual key and point this at it. Defaults to TESLA_API_BASE.
TESLA_COMMAND_BASE=
